# LLM Configuration
# LLM_PROVIDER: one of "openai", "gemini", "anthropic"
# - openai:     LLM_BASE_URL points at the OpenAI-compatible endpoint
#               (e.g. http://127.0.0.1:1234/v1 for LM Studio / Ollama)
# - gemini:     LLM_MODEL_NAME e.g. "gemini-2.5-flash". Auth is either
#               LLM_API_KEY (AI Studio) or Vertex AI — see the
#               GEMINI_USE_VERTEX block below.
# - anthropic:  LLM_MODEL_NAME e.g. "claude-opus-4-7" (recommended).
#               `temperature` is removed on Opus 4.7 and is silently
#               ignored by the provider; safe to leave at 0.
LLM_API_KEY=
LLM_MODEL_NAME=
LLM_PROVIDER=
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.0
LLM_REQUESTS_PER_MINUTE=5

# Gemini on Vertex AI (alternative to LLM_API_KEY when LLM_PROVIDER=gemini)
# Set GEMINI_USE_VERTEX=true and provide your GCP project + region. The
# provider then authenticates via Application Default Credentials — run
# `gcloud auth application-default login` locally, or rely on the
# attached service account when deployed on GCP. LLM_API_KEY is ignored
# when GEMINI_USE_VERTEX=true.
GEMINI_USE_VERTEX=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false
BATCH_CONCURRENCY=5
