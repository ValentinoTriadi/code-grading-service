# LLM Configuration
# LLM_PROVIDER: one of "openai", "gemini", "anthropic"
# - openai:     LLM_BASE_URL points at the OpenAI-compatible endpoint
#               (e.g. http://127.0.0.1:1234/v1 for LM Studio / Ollama)
# - gemini:     LLM_MODEL_NAME e.g. "gemini-2.5-flash"
# - anthropic:  LLM_MODEL_NAME e.g. "claude-opus-4-7" (recommended).
#               `temperature` is removed on Opus 4.7 and is silently
#               ignored by the provider; safe to leave at 0.
LLM_API_KEY=
LLM_MODEL_NAME=
LLM_PROVIDER=
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.0
LLM_REQUESTS_PER_MINUTE=5

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false
BATCH_CONCURRENCY=5
